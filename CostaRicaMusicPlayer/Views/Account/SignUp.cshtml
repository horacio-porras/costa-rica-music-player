@using CostaRicaMusicBLL.Dtos
@model RegisterDto
@{
    Layout = null;
    ViewData["Title"] = "Registrarse";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CostaRicaMusicPlayer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">Registrate para comenzar a escuchar</h1>

        @if (ViewBag.Error != null)
        {
            <div class="auth-error">@ViewBag.Error</div>
        }

        <form asp-action="SignUp" method="post" class="auth-form">
            <label class="auth-label" asp-for="Email">Correo electronico</label>
            <input asp-for="Email" class="auth-input" placeholder="nombre@dominio.com" />
            <span asp-validation-for="Email" class="auth-validation"></span>

            <label class="auth-label mt-3" asp-for="Username">Usuario</label>
            <input asp-for="Username" class="auth-input" placeholder="Tu usuario" />
            <span asp-validation-for="Username" class="auth-validation"></span>

            <label class="auth-label mt-3" asp-for="Password">Contraseña</label>
            <input asp-for="Password" type="password" class="auth-input" placeholder="Minimo 6 caracteres" />
            <span asp-validation-for="Password" class="auth-validation"></span>

            <button type="submit" class="auth-main-btn mt-3">Crear cuenta</button>
        </form>

        <div class="auth-divider">o</div>

        <a asp-action="Login" class="auth-link-inline">Ya tienes una cuenta?<br /><strong>Inicia sesion</strong></a>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/js/all.min.js"></script>
</body>
</html>
