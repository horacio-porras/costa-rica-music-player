@using CostaRicaMusicBLL.Dtos
@model LoginDto
@{
    Layout = null;
    ViewData["Title"] = "Iniciar sesion";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CostaRicaMusicPlayer</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">Welcome back</h1>

        @if (ViewBag.Error != null)
        {
            <div class="auth-error">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post" class="auth-form">
            <label class="auth-label" asp-for="EmailOrUsername">Email or username</label>
            <input asp-for="EmailOrUsername" class="auth-input" placeholder="name@domain.com" />
            <span asp-validation-for="EmailOrUsername" class="auth-validation"></span>

            <label class="auth-label mt-3" asp-for="Password">Password</label>
            <input asp-for="Password" type="password" class="auth-input" placeholder="Ingresa tu contrasena" />
            <span asp-validation-for="Password" class="auth-validation"></span>

            <button type="submit" class="auth-main-btn mt-3">Continue</button>
        </form>

        <div class="auth-divider">or</div>

        <a asp-action="SignUp" class="auth-link-inline">Don't have an account?<br /><strong>Sign up</strong></a>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/js/all.min.js"></script>
</body>
</html>
