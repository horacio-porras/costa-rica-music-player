@{
    ViewData["Title"] = "Explorar música";
}

<div class="music-page">
    <div class="music-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="music-title mb-1">Explora la música</h1>
            <p class="music-subtitle mb-0">Canciones y artistas de Costa Rica Music</p>
        </div>
        <div class="music-search input-group">
            <span class="input-group-text">
                <i class="bi bi-search"></i>
            </span>
            <input type="text" class="form-control" id="txtBuscarCancion" placeholder="Buscar canción, álbum o artista..." />
        </div>
    </div>

    <div class="row music-layout">
        <div class="col-lg-7 col-md-12">
            <h2 class="section-title">Canciones</h2>
            <div class="d-flex justify-content-between align-items-center mb-2">
                <small id="songsPaginationInfo" class="text-secondary"></small>
                <nav aria-label="Paginación de canciones">
                    <ul id="songsPagination" class="pagination pagination-sm mb-0"></ul>
                </nav>
            </div>
            <div id="songsGrid" class="music-grid">
                <!-- Cards de canciones renderizadas por JS -->
            </div>
        </div>

        <div class="col-lg-5 col-md-12">
            <div class="side-section mb-4">
                <h2 class="section-title">Artistas</h2>
                <div id="listaArtistas" class="artists-list">
                    <!-- Artistas renderizados por JS -->
                </div>
            </div>

            <div class="side-section">
                <h2 class="section-title">Álbumes</h2>
                <div id="listaAlbums" class="albums-list">
                    <!-- Álbumes renderizados por JS -->
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_MediaModals")

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.js"></script>
    <script src="~/js/Music.js" asp-append-version="true"></script>
}

