@{
    ViewData["Title"] = "Explorar música";
}

<div class="music-page">
    <div class="music-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="music-title mb-1">Explora tu música</h1>
            <p class="music-subtitle mb-0">Canciones y artistas de Costa Rica Music</p>
        </div>
        <div class="music-search input-group">
            <span class="input-group-text">
                <i class="bi bi-search"></i>
            </span>
            <input type="text" class="form-control" id="txtBuscarCancion" placeholder="Buscar canción o artista..." />
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <h2 class="section-title">Canciones</h2>
            <div id="songsGrid" class="music-grid">
                <!-- Cards de canciones renderizadas por JS -->
            </div>
        </div>

        <div class="col-lg-4">
            <h2 class="section-title">Artistas</h2>
            <div id="listaArtistas" class="artists-list">
                <!-- Artistas renderizados por JS -->
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="artistModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-0">

            <div class="modal-header border-secondary">
                <h5 class="modal-title">Artista</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">

                <img id="artistModalImage"
                     class="rounded-circle mb-3"
                     width="120"
                     height="120"
                     style="object-fit:cover;" />

                <h4 id="artistModalName"></h4>

                <p id="artistModalBio" class="text-secondary small"></p>

                <hr class="border-secondary">

                <h6 class="mb-3">Canciones</h6>

                <ul id="artistSongsList" class="list-group list-group-flush"></ul>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.js"></script>
    <script src="~/js/Music.js" asp-append-version="true"></script>
}

