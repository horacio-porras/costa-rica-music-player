@{
    ViewData["Title"] = "Inicio";
}

<div class="home-page">
    <!-- Sección de Playlists -->
    <section class="home-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title">Tus Playlists</h2>
            <a asp-controller="Playlists" asp-action="Index" class="view-all-link">
                Ver todas <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div id="playlistsGrid" class="home-grid">
            <!-- Playlists cargadas por JS -->
        </div>
    </section>

    <!-- Sección de Canciones Recomendadas -->
    <section class="home-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title">Canciones Recomendadas</h2>
            <a asp-controller="Music" asp-action="Index" class="view-all-link">
                Ver todas <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div id="recommendedSongsGrid" class="home-grid">
            <!-- Canciones cargadas por JS -->
        </div>
    </section>

    <!-- Sección de Artistas Recomendados -->
    <section class="home-section">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title">Artistas Recomendados</h2>
            <a asp-controller="Music" asp-action="Index" class="view-all-link">
                Ver todos <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div id="recommendedArtistsGrid" class="home-artists-grid">
            <!-- Artistas cargados por JS -->
        </div>
    </section>
</div>

<!-- Modal de Artista (reutilizado de Music) -->
<div class="modal fade" id="artistModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-0">
            <div class="modal-header border-secondary">
                <h5 class="modal-title">Artista</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <img id="artistModalImage"
                     class="rounded-circle mb-3"
                     width="120"
                     height="120"
                     style="object-fit:cover;" />
                <h4 id="artistModalName"></h4>
                <p id="artistModalBio" class="text-secondary small"></p>
                <hr class="border-secondary">
                <h6 class="mb-3">Canciones</h6>
                <ul id="artistSongsList" class="list-group list-group-flush"></ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.js"></script>
    <script src="~/js/Home.js" asp-append-version="true"></script>
}