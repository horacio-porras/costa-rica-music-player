@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Inicio";
    var usuarioAutenticado = Context.Session.GetInt32("UserId").HasValue;
}

<div class="home-layout">
    <aside class="home-library-sidebar">
        <div class="home-library-header">
            <h2 class="home-library-title mb-0">Tu biblioteca</h2>
            <button type="button" class="home-library-create-btn js-home-create-playlist">
                <span class="home-library-create-plus" aria-hidden="true">+</span> Crear
            </button>
        </div>

        <div id="userLibraryList" class="home-library-list">
            <!-- Playlists del usuario -->
        </div>
    </aside>

    <div class="home-page">
        <div id="homeDiscoveryContent">
            <div class="music-page px-0 pt-0">
                <div class="music-header d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1 class="music-title mb-1">Explora la música</h1>
                        <p class="music-subtitle mb-0">Canciones y artistas de Costa Rica Music</p>
                    </div>
                    <div class="music-search input-group">
                        <span class="input-group-text">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" class="form-control" id="txtBuscarCancion" placeholder="Buscar canción, álbum o artista..." />
                    </div>
                </div>

                <div class="row music-layout">
                    <div class="col-lg-7 col-md-12">
                        <h2 class="section-title">Canciones</h2>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <small id="songsPaginationInfo" class="text-secondary"></small>
                            <nav aria-label="Paginación de canciones">
                                <ul id="songsPagination" class="pagination pagination-sm mb-0"></ul>
                            </nav>
                        </div>
                        <div id="songsGrid" class="music-grid">
                            <!-- Canciones cargadas por JS -->
                        </div>
                    </div>

                    <div class="col-lg-5 col-md-12">
                        <div class="side-section mb-4">
                            <h2 class="section-title">Artistas</h2>
                            <div id="listaArtistas" class="artists-list">
                                <!-- Artistas cargados por JS -->
                            </div>
                        </div>

                        <div class="side-section">
                            <h2 class="section-title">Álbumes</h2>
                            <div id="listaAlbums" class="albums-list">
                                <!-- Álbumes cargados por JS -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="homePlaylistDetailContainer" class="home-playlist-detail-container d-none">
            <!-- Detalle playlist embebido -->
        </div>
    </div>
</div>
@await Html.PartialAsync("~/Views/Playlists/_Create.cshtml")
@await Html.PartialAsync("~/Views/Playlists/_Edit.cshtml")
@await Html.PartialAsync("_MediaModals")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.js"></script>
    <script>
        window.homeIsAuthenticated = @(usuarioAutenticado ? "true" : "false");
    </script>
    <script src="~/js/Home.js" asp-append-version="true"></script>
}